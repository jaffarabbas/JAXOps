<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — IIS Manager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="d-flex flex-column vh-100 bg-light">

    <!-- Top navbar -->
    <nav class="navbar navbar-dark bg-dark px-3 py-2 shadow-sm flex-shrink-0">
        <a class="navbar-brand fw-bold" href="/">
            <i class="bi bi-server me-2"></i>IIS Manager
        </a>
        <div class="d-flex align-items-center gap-3 ms-auto">
            <span class="text-white-50 small"><i class="bi bi-person-circle me-1"></i>@User.Identity?.Name</span>
            <div id="notification-bell" class="position-relative" style="cursor:pointer">
                <i class="bi bi-bell text-white fs-5"></i>
                <span id="notification-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
            </div>
        </div>
    </nav>

    <div class="d-flex flex-grow-1 overflow-hidden">
        <!-- Sidebar -->
        <partial name="_Sidebar" />

        <!-- Main content -->
        <main class="flex-grow-1 overflow-auto p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
