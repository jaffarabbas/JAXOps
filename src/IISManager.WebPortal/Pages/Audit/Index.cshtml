@page
@model IISManager.WebPortal.Pages.Audit.AuditIndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Audit Logs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-journal-text me-2 text-primary"></i>Audit Logs</h1>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 small">
            <thead class="table-light">
                <tr>
                    <th>Time</th><th>Action</th><th>Entity</th><th>Description</th><th>Performed By</th><th>IP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs.Items)
                {
                    <tr>
                        <td class="text-muted text-nowrap">@log.PerformedAt.ToString("dd/MM/yy HH:mm:ss")</td>
                        <td><span class="badge bg-secondary">@log.Action</span></td>
                        <td>@log.EntityType @(log.EntityId != null ? "#" + log.EntityId : "")</td>
                        <td>@log.Description</td>
                        <td>@log.PerformedBy</td>
                        <td class="text-muted">@(log.IpAddress ?? "—")</td>
                    </tr>
                }
                @if (!Model.Logs.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No audit logs found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Logs.TotalPages > 1)
    {
        <div class="card-footer bg-white">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int p = 1; p <= Model.Logs.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Logs.Page ? "active" : "")">
                            <a class="page-link" href="?page=@p">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
