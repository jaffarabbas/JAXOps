@page
@model IISManager.WebPortal.Pages.Agents.AgentsIndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Agent Logs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-terminal me-2 text-primary"></i>Agent Logs</h1>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Server</th>
                    <th>Hostname</th>
                    <th>Environment</th>
                    <th>Status</th>
                    <th>Last Heartbeat</th>
                    <th>Agent Version</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Servers)
                {
                    var (badgeCss, dot) = s.Status.ToString() switch
                    {
                        "Online"  => ("bg-success", "text-success"),
                        "Offline" => ("bg-danger",  "text-danger"),
                        "Warning" => ("bg-warning text-dark", "text-warning"),
                        _         => ("bg-secondary", "text-secondary")
                    };
                    <tr>
                        <td class="fw-semibold">
                            <i class="bi bi-circle-fill @dot me-1" style="font-size:.55rem;vertical-align:middle"></i>
                            @s.Name
                        </td>
                        <td class="text-muted small">@s.Hostname</td>
                        <td><span class="badge bg-secondary">@s.Environment</span></td>
                        <td><span class="badge @badgeCss">@s.Status</span></td>
                        <td class="text-muted small">@(s.LastHeartbeat?.ToString("dd/MM HH:mm:ss") ?? "Never")</td>
                        <td class="text-muted small">@(s.AgentVersion ?? "—")</td>
                        <td>
                            <a href="/Agents/Logs?serverId=@s.Id"
                               class="btn btn-sm @(s.IsOnline ? "btn-primary" : "btn-outline-secondary")"
                               title="@(s.IsOnline ? "View Live Logs" : "Agent offline — log history only")">
                                <i class="bi bi-terminal me-1"></i>
                                @(s.IsOnline ? "Live Log" : "Log History")
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Servers.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            No agents registered yet. <a href="/Servers/Create">Add a server.</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
