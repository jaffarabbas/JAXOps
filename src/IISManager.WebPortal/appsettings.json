{
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1,1433;Database=IISManagerDb;User Id=sa;Password=YourStrongPassword!;TrustServerCertificate=True;"
  },
  "Portal": {
    "UseWindowsAuth": false,
    "PackageStorePath": "C:\\IISManagerPackages",
    "MaxPackageSizeMB": 500,
    "HealthSnapshotRetentionDays": 30
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/portal-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
