<Application x:Class="DeploymentTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DeploymentTool"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F0F2F5"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="BorderBrushTheme" Color="#DDE1E7"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#444444"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextFaintBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryBackgroundBrush" Color="#F8F8F8"/>
    <SolidColorBrush x:Key="ButtonSecondaryForegroundBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="DataGridRowHighlightBrush" Color="#FFFBEB"/>
    <SolidColorBrush x:Key="TreeNewBrush" Color="#F0FDF4"/>
    <SolidColorBrush x:Key="TreeModifiedBrush" Color="#FFFBEB"/>
    <SolidColorBrush x:Key="LogPanelBrush" Color="#111827"/>
    <SolidColorBrush x:Key="LogInputBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#FFFFFF"/>
    </Application.Resources>
</Application>
