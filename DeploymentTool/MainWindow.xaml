<Window x:Class="DeploymentTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DeploymentTool.ViewModels"
        Title="JAXOps"
        Height="860" Width="1280" MinHeight="700" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Opacity" Value="0.45"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonSecondaryForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBackgroundBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="CaretBrush" Value="#1D4ED8"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource TabBackgroundBrush}"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceMutedBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrushTheme}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrushTheme}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushTheme}"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>      <!-- header -->
            <RowDefinition Height="*"/>       <!-- content -->
            <RowDefinition Height="190"/>     <!-- log -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1F2937">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙" FontSize="18" Foreground="#6EE7B7" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="JAXOps" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="  v1.0" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="140" Height="6"
                                 Foreground="#6EE7B7" Background="#374151"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="Working…" Foreground="#9CA3AF" FontSize="11" Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ═════════════════════════════════════════════════════ -->
        <TabControl Grid.Row="1" Margin="10,8,10,0"
                    Background="Transparent" BorderThickness="0"
                    Padding="0">

            <!-- ── PUBLISH TAB ─────────────────────────────────────────────── -->
            <TabItem Header="  Publish  " FontSize="13">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- config strip -->
                        <RowDefinition Height="*"/>      <!-- project + compare panels -->
                        <RowDefinition Height="Auto"/>   <!-- action buttons -->
                    </Grid.RowDefinitions>

                    <!-- CONFIG STRIP ─────────────────────────────────────── -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Codebase" Style="{StaticResource SectionLabel}" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding FilteredCodebases}"
                                      SelectedItem="{Binding SelectedCodebase}"
                                      DisplayMemberPath="Name"
                                      Height="30" VerticalContentAlignment="Center"/>

                                <TextBox Grid.Column="3"
                                     Text="{Binding CodebaseSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30" VerticalContentAlignment="Center"
                                     Padding="6,0" FontSize="11"
                                     ToolTip="Search codebases by name or path"/>

                                <TextBlock Grid.Column="5" Text="Output Folder" Style="{StaticResource SectionLabel}" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="6"
                                     Text="{Binding PublishOutputFolder, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30" VerticalContentAlignment="Center"
                                     Padding="6,0" FontFamily="Consolas" FontSize="12"/>
                                <Button Grid.Column="7" Content="Browse…"
                                    Command="{Binding BrowseOutputFolderCommand}"
                                    Style="{StaticResource SmallBtn}"
                                    Height="30" Margin="6,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- PROJECTS PANEL ──────────────────────────────────── -->
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- panel header -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Projects" Style="{StaticResource SectionLabel}" FontSize="13"/>
                                        <Border Background="#E0F2FE" CornerRadius="10" Padding="7,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Projects.Count}" FontSize="11" Foreground="#0369A1"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="All" Command="{Binding SelectAllProjectsCommand}" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                        <Button Content="None" Command="{Binding ClearProjectsCommand}" Style="{StaticResource SmallBtn}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- projects grid -->
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Projects}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{DynamicResource BorderBrushTheme}"
                                          BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}"
                                          RowHeight="30"
                                          FontSize="12"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          EnableRowVirtualization="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <!-- single-click checkbox via template column -->
                                        <DataGridTemplateColumn Header="✓" Width="42" CanUserSort="False">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Project Name" Width="*" CanUserSort="True" SortMemberPath="Name">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                        <Border Background="#D1FAE5" CornerRadius="4" Padding="4,1" Margin="6,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding IsPublishedFolder, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="published" FontSize="10" Foreground="#065F46"/>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                    <Setter Property="ToolTip" Value="{Binding Path}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- publish button -->
                                <Button Grid.Row="2"
                                        Content="▶  Publish Selected"
                                        Command="{Binding PublishCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#059669"
                                        Margin="0,10,0,0"/>
                            </Grid>
                        </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════════ -->
            <!-- PATCH TAB                                                          -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <TabItem Header="  Patch  " FontSize="13">
                <Grid Margin="0,8,0,0">
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- 0: title + filter bar -->
                                <RowDefinition Height="Auto"/>  <!-- 1: compare progress -->
                                <RowDefinition Height="Auto"/>  <!-- 2: NEW folder / Single folder row -->
                                <RowDefinition Height="Auto"/>  <!-- 3: OLD folder row (two-folder mode) -->
                                <RowDefinition Height="Auto"/>  <!-- 4: Since Date row (single folder mode) -->
                                <RowDefinition Height="Auto"/>  <!-- 5: search bar -->
                                <RowDefinition Height="*"/>     <!-- 6: file tree -->
                                <RowDefinition Height="Auto"/>  <!-- 7: patch config -->
                                <RowDefinition Height="Auto"/>  <!-- 8: patch button -->
                            </Grid.RowDefinitions>

                            <!-- title bar -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Compare &amp; Patch" Style="{StaticResource SectionLabel}" FontSize="13"/>
                                    <Border Background="#FEF3C7" CornerRadius="10" Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="#92400E">
                                            <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                            <Run Text=" total"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#FEF9C3" CornerRadius="10" Padding="7,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="#78350F">
                                            <Run Text="{Binding ModifiedCount, Mode=OneWay}"/>
                                            <Run Text=" modified"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#D1FAE5" CornerRadius="10" Padding="7,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="#065F46">
                                            <Run Text="{Binding NewCount, Mode=OneWay}"/>
                                            <Run Text=" new"/>
                                        </TextBlock>
                                    </Border>
                                    <ComboBox ItemsSource="{Binding FilterOptions}"
                                              SelectedItem="{Binding SelectedFilterOption}"
                                              DisplayMemberPath="Label"
                                              Height="26" Width="130"
                                              Margin="10,0,0,0"
                                              VerticalContentAlignment="Center"
                                              FontSize="11"/>
                                    <ComboBox ItemsSource="{Binding CompareModeOptions}"
                                              SelectedItem="{Binding SelectedCompareModeOption}"
                                              DisplayMemberPath="Label"
                                              Height="26" Width="120"
                                              Margin="6,0,0,0"
                                              VerticalContentAlignment="Center"
                                              FontSize="11"/>
                                </StackPanel>
                            </Grid>

                            <!-- compare progress bar -->
                            <Grid Grid.Row="1" Margin="0,0,0,4"
                                  Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Grid.Column="0" IsIndeterminate="True" Height="6"
                                             Foreground="#1D4ED8" Background="#DBEAFE"
                                             VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Comparing…" FontSize="10"
                                           Foreground="#1D4ED8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>

                            <!-- Two-folder: NEW folder row -->
                            <Grid Grid.Row="2" Margin="0,0,0,4"
                                  Visibility="{Binding IsTwoFolderMode, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="NEW" FontSize="10" FontWeight="Bold"
                                           Foreground="#065F46" Background="#D1FAE5"
                                           Padding="4,2" VerticalAlignment="Center" TextAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding NewCompareFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Height="26" VerticalContentAlignment="Center"
                                         Padding="4,0" FontFamily="Consolas" FontSize="11"
                                         BorderBrush="#D1D5DB" Margin="4,0"/>
                                <Button Grid.Column="2" Content="Browse"
                                        Command="{Binding BrowseNewCompareFolderCommand}"
                                        Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                <Button Grid.Column="3" Content="&#x21C4; Compare"
                                        Command="{Binding CompareCommand}"
                                        Style="{StaticResource SmallBtn}"
                                        Background="#1D4ED8" Foreground="White" BorderThickness="0"
                                        FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Single-folder: FOLDER input row -->
                            <Grid Grid.Row="2" Margin="0,0,0,4">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSingleFolderMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="FOLDER" FontSize="9" FontWeight="Bold"
                                           Foreground="#1D4ED8" Background="#DBEAFE"
                                           Padding="4,2" VerticalAlignment="Center" TextAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SingleCompareFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Height="26" VerticalContentAlignment="Center"
                                         Padding="4,0" FontFamily="Consolas" FontSize="11"
                                         BorderBrush="#D1D5DB" Margin="4,0"/>
                                <Button Grid.Column="2" Content="Browse"
                                        Command="{Binding BrowseSingleFolderCommand}"
                                        Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                <Button Grid.Column="3" Content="&#x1F50D; Scan"
                                        Command="{Binding CompareCommand}"
                                        Style="{StaticResource SmallBtn}"
                                        Background="#1D4ED8" Foreground="White" BorderThickness="0"
                                        FontWeight="SemiBold"/>
                            </Grid>

                            <!-- OLD folder row (two-folder mode only) -->
                            <Grid Grid.Row="3" Margin="0,0,0,4"
                                  Visibility="{Binding IsTwoFolderMode, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="2" Text="OLD" FontSize="10" FontWeight="Bold"
                                           Foreground="#92400E" Background="#FEF3C7"
                                           Padding="4,2" VerticalAlignment="Center" TextAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding OldCompareFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Height="26" VerticalContentAlignment="Center"
                                         Padding="4,0" FontFamily="Consolas" FontSize="11"
                                         BorderBrush="#D1D5DB" Margin="4,0"/>
                                <Button Grid.Column="2" Content="Browse"
                                        Command="{Binding BrowseOldCompareFolderCommand}"
                                        Style="{StaticResource SmallBtn}"/>
                            </Grid>

                            <!-- Since Date row (single folder mode only) -->
                            <Grid Grid.Row="4" Margin="0,0,0,4">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSingleFolderMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Since" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker Grid.Column="1"
                                            SelectedDate="{Binding SinceDate, UpdateSourceTrigger=PropertyChanged}"
                                            Height="26" FontSize="11" Margin="0,0,8,0"
                                            ToolTip="Show files modified or created on/after this date"/>
                                <TextBlock Grid.Column="2" FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                                           VerticalAlignment="Center"
                                           Text="Files modified/created on or after this date"/>
                            </Grid>

                            <!-- search bar -->
                            <Grid Grid.Row="5" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Grid Grid.Column="1">
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Height="26" VerticalContentAlignment="Center"
                                             Padding="6,0" FontFamily="Consolas" FontSize="11"
                                             BorderBrush="#D1D5DB"/>
                                    <TextBlock Text="Search files…" Foreground="{DynamicResource TextFaintBrush}"
                                               FontStyle="Italic" FontSize="11"
                                               VerticalAlignment="Center" Margin="8,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                    <Button Content="All"  Command="{Binding SelectAllChangesCommand}" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                    <Button Content="None" Command="{Binding ClearChangesCommand}"     Style="{StaticResource SmallBtn}"/>
                                </StackPanel>
                            </Grid>

                            <!-- file tree -->
                            <TreeView Grid.Row="6"
                                      ItemsSource="{Binding FileTree}"
                                      BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}"
                                      Background="{DynamicResource SurfaceBrush}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="1,1"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <Border Padding="2,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FileChange.Status}" Value="New">
                                                            <Setter Property="Background" Value="{DynamicResource TreeNewBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                            <Setter Property="Background" Value="{DynamicResource TreeModifiedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          VerticalAlignment="Center" Margin="0,0,4,0"/>

                                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                           Margin="0,0,3,0" FontSize="13">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="📄"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Text" Value="📁"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBlock Grid.Column="2" Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Consolas" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                                    <Setter Property="FontSize" Value="12"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- status badge — files only -->
                                                <Border Grid.Column="3" Margin="6,2,0,2"
                                                        CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#D1FAE5"/>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                                    <Setter Property="Background" Value="#FEF9C3"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FileChange.Status}" Value="Unchanged">
                                                                    <Setter Property="Background" Value="#F3F4F6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding FileChange.StatusLabel}"
                                                               FontSize="10" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#065F46"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                                        <Setter Property="Foreground" Value="#78350F"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FileChange.Status}" Value="Unchanged">
                                                                        <Setter Property="Foreground" Value="#6B7280"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <!-- timestamp — files only -->
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding FileChange.LastWriteTimeLabel}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource TextFaintBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,2,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <!-- patch config -->
                            <Grid Grid.Row="7" Margin="0,8,0,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- patch output root (read-only) -->
                                <Grid Grid.Row="0" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Output" FontSize="10"
                                               FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding PatchOutputRoot, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Height="24" VerticalContentAlignment="Center"
                                             Padding="4,0" FontFamily="Consolas" FontSize="10"
                                             Background="{DynamicResource SurfaceMutedBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             ToolTip="{Binding PatchOutputRoot}"/>
                                </Grid>

                                <!-- patch folder name (editable) -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Name" FontSize="10"
                                               FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding PatchName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="24" VerticalContentAlignment="Center"
                                             Padding="4,0" FontFamily="Consolas" FontSize="11"
                                             BorderBrush="#A78BFA"
                                             ToolTip="Folder name for this patch (inside Output)"/>
                                </Grid>
                            </Grid>

                            <!-- patch button -->
                            <Button Grid.Row="8"
                                    Content="📦  Create Patch"
                                    Command="{Binding CreatePatchCommand}"
                                    Style="{StaticResource PrimaryBtn}"
                                    Background="#7C3AED"
                                    Margin="0,4,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── APPSETTINGS TAB ─────────────────────────────────────────── -->
            <TabItem Header="  AppSettings  " FontSize="13">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- global changer bar -->
                        <RowDefinition Height="*"/>      <!-- two panels -->
                    </Grid.RowDefinitions>

                    <!-- GLOBAL CHANGER BAR ──────────────────────────────── -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Global Key"
                                       Style="{StaticResource SectionLabel}"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding GlobalKey, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30" VerticalContentAlignment="Center"
                                     Padding="6,0" FontFamily="Consolas" FontSize="12"
                                     BorderBrush="{DynamicResource InputBorderBrush}"
                                     ToolTip="Key to update (use : for nested JSON, e.g. Logging:LogLevel:Default)"/>

                            <TextBlock Grid.Column="4" Text="New Value"
                                       Style="{StaticResource SectionLabel}"/>
                            <TextBox Grid.Column="6"
                                     Text="{Binding GlobalValue, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30" VerticalContentAlignment="Center"
                                     Padding="6,0" FontFamily="Consolas" FontSize="12"
                                     BorderBrush="{DynamicResource InputBorderBrush}"
                                     ToolTip="Value to write into every matching key"/>

                            <Button Grid.Column="8"
                                    Content="Apply to Selected Files"
                                    Command="{Binding ApplyGlobalChangeCommand}"
                                    Style="{StaticResource PrimaryBtn}"
                                    Background="#D97706"
                                    Height="30"
                                    FontSize="11"
                                    Padding="10,0"/>

                            <Button Grid.Column="10"
                                    Content="Save All Modified"
                                    Command="{Binding SaveAllModifiedCommand}"
                                    Style="{StaticResource PrimaryBtn}"
                                    Background="#059669"
                                    Height="30"
                                    FontSize="11"
                                    Padding="10,0"/>
                        </Grid>
                    </Border>

                    <!-- TWO PANELS ──────────────────────────────────────── -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>    <!-- file list -->
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="2*"/>   <!-- editor -->
                        </Grid.ColumnDefinitions>

                    <!-- LEFT: Config File List ───────────────────────────── -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- header + load button -->
                                <RowDefinition Height="*"/>      <!-- file list -->
                            </Grid.RowDefinitions>

                            <!-- header row -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Config Files" Style="{StaticResource SectionLabel}" FontSize="13"/>
                                    <Border Background="#E0F2FE" CornerRadius="10" Padding="7,1"
                                            Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="#0369A1">
                                            <Run Text="{Binding ConfigFiles.Count, Mode=OneWay}"/>
                                            <Run Text=" found"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="All"  Command="{Binding SelectAllFilesCommand}"
                                            Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                    <Button Content="None" Command="{Binding ClearFilesCommand}"
                                            Style="{StaticResource SmallBtn}" Margin="0,0,8,0"/>
                                        <Button Content="Load Config Files"
                                            Command="{Binding LoadConfigFilesCommand}"
                                            Style="{StaticResource PrimaryBtn}"
                                            Background="#1D4ED8"
                                            Height="26"
                                            FontSize="11"
                                            Padding="10,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- file list grid -->
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ConfigFiles}"
                                      SelectedItem="{Binding SelectedConfigFile}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderBrushTheme}"
                                      BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}"
                                      RowHeight="30" FontSize="12"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      EnableRowVirtualization="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource DataGridRowHighlightBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.Columns>
                                    <!-- checkbox column for global-change selection -->
                                    <DataGridTemplateColumn Header="✓" Width="36" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="File Name"
                                                        Binding="{Binding FileName}"
                                                        IsReadOnly="True"
                                                        Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="ToolTip" Value="{Binding FilePath}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Folder"
                                                        Binding="{Binding SubFolder}"
                                                        IsReadOnly="True"
                                                        Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                <Setter Property="ToolTip" Value="{Binding FilePath}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Service"
                                                        Binding="{Binding ServiceName}"
                                                        IsReadOnly="True"
                                                        Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Type"
                                                        Binding="{Binding FileType}"
                                                        IsReadOnly="True"
                                                        Width="44">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="10"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- modified badge -->
                                    <DataGridTemplateColumn Header="" Width="68" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="3" Padding="5,1"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value=""/>
                                                                <Setter Property="Foreground" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                                        <Setter Property="Text" Value="● modified"/>
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- RIGHT: File Editor ───────────────────────────────── -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- editor header -->
                                <RowDefinition Height="*"/>      <!-- text editor -->
                                <RowDefinition Height="Auto"/>   <!-- save button -->
                            </Grid.RowDefinitions>

                            <!-- editor header -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding EditorTitle}"
                                               Style="{StaticResource SectionLabel}" FontSize="13"/>
                                    <Border CornerRadius="4" Padding="6,1" Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsEditorDirty, Converter={StaticResource BoolToVis}}">
                                        <Border.Background>
                                            <SolidColorBrush Color="#FEF3C7"/>
                                        </Border.Background>
                                        <TextBlock Text="● unsaved" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#92400E"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           FontFamily="Consolas" FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                                           Text="{Binding SelectedConfigFile.FilePath}"
                                           ToolTip="{Binding SelectedConfigFile.FilePath}"/>

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBox x:Name="EditorSearchBox"
                                             Text="{Binding EditorSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="EditorSearchBox_TextChanged"
                                             Width="260" Height="24" VerticalContentAlignment="Center"
                                             Padding="6,0" FontFamily="Consolas" FontSize="11"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             ToolTip="Find text in current editor"/>
                                    <Button Content="Find Next"
                                            Style="{StaticResource SmallBtn}"
                                            Margin="6,0,0,0"
                                            Click="FindInEditor_Click"/>
                                        <Button Content="Validate Config"
                                            Command="{Binding ValidateSelectedJsonCommand}"
                                            Style="{StaticResource SmallBtn}"
                                            Margin="6,0,0,0"
                                                          ToolTip="Validate JSON/XML syntax (shows line and column on errors)"/>
                                        <TextBlock Text="{Binding ValidationErrorLinesSummary}"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               Foreground="#B91C1C"/>
                                </StackPanel>
                            </Grid>

                            <!-- text editor area -->
                            <Grid Grid.Row="1">
                                <!-- placeholder when no file is open -->
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFaintBrush}" FontStyle="Italic" FontSize="13"
                                           Text="&#x2190;  Click a config file in the list to open it here"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedConfigFile}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- actual editor -->
                                <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}" CornerRadius="4">
                                    <ScrollViewer x:Name="EditorScrollViewer"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrushTheme}" BorderThickness="0,0,1,0">
                                                <ItemsControl ItemsSource="{Binding EditorLines}" IsHitTestVisible="False" Margin="0,10,0,10">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="6,0,6,0" MinHeight="18" Background="Transparent">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                                <Setter Property="Background" Value="#FCA5A5"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Number}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="12"
                                                                           TextAlignment="Right">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#991B1B"/>
                                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>

                                            <ItemsControl Grid.Column="1"
                                                          ItemsSource="{Binding EditorLines}"
                                                          IsHitTestVisible="False"
                                                          Margin="0,10,0,10"
                                                          Panel.ZIndex="2">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border MinHeight="18" Background="Transparent">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                            <Setter Property="Background" Value="#33EF4444"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBox Grid.Column="1"
                                                     Text="{Binding EditorContent, UpdateSourceTrigger=PropertyChanged}"
                                                     x:Name="EditorTextBox"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     IsInactiveSelectionHighlightEnabled="True"
                                                     SelectionBrush="#FBBF24"
                                                     SelectionTextBrush="#1F2937"
                                                     AcceptsReturn="True"
                                                     AcceptsTab="True"
                                                     TextWrapping="NoWrap"
                                                     BorderThickness="0"
                                                     Padding="10"
                                                     Background="Transparent"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     CaretBrush="#1D4ED8"
                                                     VerticalAlignment="Stretch"
                                                     HorizontalAlignment="Stretch"
                                                     Panel.ZIndex="1"
                                                     VerticalScrollBarVisibility="Disabled"
                                                     HorizontalScrollBarVisibility="Disabled">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedConfigFile}" Value="{x:Null}">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Grid>

                                <!-- action buttons -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                                <Button Content="Save File"
                                    Command="{Binding SaveFileCommand}"
                                    Style="{StaticResource PrimaryBtn}"
                                    Background="#059669"/>
                                </StackPanel>
                        </Grid>
                    </Border>
                    </Grid>  <!-- /TWO PANELS -->
                </Grid>
            </TabItem>

            <!-- ── SETTINGS TAB ─────────────────────────────────────────────── -->
            <TabItem Header="  Settings  " FontSize="13">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Codebases header card with collapse toggle -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Toggle collapse button -->
                            <Button Grid.Column="0" Command="{Binding ToggleCodebasesCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0,0,6,0">
                                <TextBlock FontSize="10" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="▼"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCodebasesExpanded}" Value="False">
                                                    <Setter Property="Text" Value="▶"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                            <TextBlock Grid.Column="1" Text="Codebases — Add multiple codebases and save directly to appsettings.json"
                                       VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        Visibility="{Binding IsCodebasesExpanded, Converter={StaticResource BoolToVis}}">
                                <Button Content="+ Add" Command="{Binding AddSettingsCodebaseCommand}"
                                        Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                <Button Content="Remove" Command="{Binding RemoveSettingsCodebaseCommand}"
                                        Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                <Button Content="Remove All" Command="{Binding RemoveAllSettingsCodebasesCommand}"
                                        Style="{StaticResource SmallBtn}" Margin="0,0,4,0"
                                        Foreground="#DC2626"/>
                                <Button Content="Browse Path" Command="{Binding BrowseSettingsCodebasePathCommand}"
                                        Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                <Button Content="Add Multiple" Command="{Binding AddMultipleCodebasesCommand}"
                                        Style="{StaticResource SmallBtn}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Collapsible: search + DataGrid -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,8"
                                    Visibility="{Binding IsCodebasesExpanded, Converter={StaticResource BoolToVis}}">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="280"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Search" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Margin="8,0,0,0"
                                             Text="{Binding SettingsCodebaseSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Height="30" VerticalContentAlignment="Center"
                                             Padding="6,0" FontSize="11"
                                             ToolTip="Filter codebase table by name or path"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <DataGrid ItemsSource="{Binding FilteredSettingsCodebases}"
                                          SelectedItem="{Binding SelectedSettingsCodebase}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{DynamicResource BorderBrushTheme}"
                                          BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}"
                                          RowHeight="32" FontSize="12" Height="240"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          EnableRowVirtualization="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Codebase Name"
                                                            Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="220"/>
                                        <DataGridTextColumn Header="Codebase Path"
                                                            Binding="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>

                        <!-- Always visible: publish output + appearance -->
                        <Border Grid.Row="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Publish Output Root" Style="{StaticResource SectionLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding SettingsPublishOutputRoot, UpdateSourceTrigger=PropertyChanged}"
                                         Height="30" VerticalContentAlignment="Center"
                                         Padding="6,0" FontFamily="Consolas" FontSize="12"
                                         BorderBrush="{DynamicResource InputBorderBrush}" Margin="8,0,6,0"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="Browse..."
                                        Command="{Binding BrowseSettingsPublishOutputCommand}"
                                        Style="{StaticResource SmallBtn}" Height="30"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Patch Output Root" Style="{StaticResource SectionLabel}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding SettingsPatchOutputRoot, UpdateSourceTrigger=PropertyChanged}"
                                         Height="30" VerticalContentAlignment="Center"
                                         Padding="6,0" FontFamily="Consolas" FontSize="12"
                                         BorderBrush="{DynamicResource InputBorderBrush}" Margin="8,0,6,0"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="Browse..."
                                        Command="{Binding BrowseSettingsPatchOutputCommand}"
                                        Style="{StaticResource SmallBtn}" Height="30"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Appearance" Style="{StaticResource SectionLabel}"/>
                                <CheckBox Grid.Row="4" Grid.Column="1"
                                          IsChecked="{Binding IsDarkMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Content="Enable dark mode"
                                          VerticalAlignment="Center"
                                          Margin="8,0,6,0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Button Grid.Row="2" Margin="0,8,0,0"
                            Content="Save Settings to appsettings.json"
                            Command="{Binding SaveSettingsCommand}"
                            Style="{StaticResource PrimaryBtn}"
                            Background="#1D4ED8"/>
                </Grid>
            </TabItem>
            <!-- ── DEPLOY TAB ─────────────────────────────────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <!-- TRANSFER TAB                                                      -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <TabItem Header="  Transfer  " FontSize="13">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- top: connection + source + transfer config -->
                        <RowDefinition Height="*"/>     <!-- log -->
                    </Grid.RowDefinitions>

                    <!-- ── TOP SECTION ──────────────────────────────────────────── -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- 0: Server + Credentials -->
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>  <!-- 2: Transfer mode + FTP/SMB fields -->
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>  <!-- 4: Source folder -->
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>  <!-- 6: Progress + Buttons -->
                            </Grid.RowDefinitions>

                            <!-- Row 0: Server + Credentials -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Server / Host" Style="{StaticResource SectionLabel}"/>
                                <TextBox   Grid.Column="1"
                                           Text="{Binding Transfer.ServerHostname, UpdateSourceTrigger=PropertyChanged}"
                                           Height="30" VerticalContentAlignment="Center"
                                           Padding="6,0" FontFamily="Consolas" FontSize="12"
                                           ToolTip="IP address or hostname of the FTP/SMB server"/>

                                <TextBlock Grid.Column="3" Text="Username" Style="{StaticResource SectionLabel}"/>
                                <TextBox   Grid.Column="4"
                                           Text="{Binding Transfer.Username, UpdateSourceTrigger=PropertyChanged}"
                                           Height="30" VerticalContentAlignment="Center"
                                           Padding="6,0" FontFamily="Consolas" FontSize="12"/>

                                <TextBlock Grid.Column="6" Text="Password" Style="{StaticResource SectionLabel}"/>
                                <PasswordBox Grid.Column="7"
                                             x:Name="TransferPasswordBox"
                                             PasswordChanged="TransferPasswordBox_PasswordChanged"
                                             Height="30"
                                             Padding="6,4"
                                             FontFamily="Consolas" FontSize="12"
                                             Background="{DynamicResource InputBackgroundBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"/>
                            </Grid>

                            <!-- Row 2: Transfer mode + connection-specific fields -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Transfer via" Style="{StaticResource SectionLabel}"/>
                                <RadioButton Grid.Column="1" Content="FTP"
                                             IsChecked="{Binding Transfer.UseFtp, Mode=TwoWay}"
                                             GroupName="TransferMode"
                                             VerticalAlignment="Center"/>
                                <RadioButton Grid.Column="3" Content="SMB (file share)"
                                             IsChecked="{Binding Transfer.UseSmb, Mode=TwoWay}"
                                             GroupName="TransferMode"
                                             VerticalAlignment="Center"/>

                                <!-- FTP: Root Path + Port + Passive (visible when UseFtp) -->
                                <Grid Grid.Column="5">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Transfer.UseFtp}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="35"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="FTP Root" Style="{StaticResource SectionLabel}"
                                               ToolTip="FTP directory to upload the ZIP into. e.g. /patches"/>
                                    <TextBox   Grid.Column="1"
                                               Text="{Binding Transfer.FtpRootPath, UpdateSourceTrigger=PropertyChanged}"
                                               Height="30" VerticalContentAlignment="Center"
                                               Padding="6,0" FontFamily="Consolas" FontSize="12"
                                               ToolTip="FTP upload path — e.g. /patches or /"/>
                                    <TextBlock Grid.Column="3" Text="Port" Style="{StaticResource SectionLabel}"/>
                                    <TextBox   Grid.Column="4"
                                               Text="{Binding Transfer.FtpPort, UpdateSourceTrigger=PropertyChanged}"
                                               Height="30" VerticalContentAlignment="Center"
                                               Padding="6,0" FontFamily="Consolas" FontSize="12"/>
                                    <CheckBox  Grid.Column="6" Content="Passive mode"
                                               IsChecked="{Binding Transfer.FtpPassiveMode}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- SMB: Share Name + Deploy Root (visible when UseSmb) -->
                                <Grid Grid.Column="5">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Transfer.UseFtp}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Share Name" Style="{StaticResource SectionLabel}"
                                               ToolTip="Custom SMB share name — e.g. patches. Blank = use admin share."/>
                                    <TextBox   Grid.Column="1"
                                               Text="{Binding Transfer.ShareName, UpdateSourceTrigger=PropertyChanged}"
                                               Height="30" VerticalContentAlignment="Center"
                                               Padding="6,0" FontFamily="Consolas" FontSize="12"
                                               ToolTip="e.g. patches → \\SERVER\patches"/>
                                    <TextBlock Grid.Column="3" Text="Root Path" Style="{StaticResource SectionLabel}"
                                               ToolTip="Local path on the server. e.g. C:\patches"/>
                                    <TextBox   Grid.Column="4"
                                               Text="{Binding Transfer.DeploymentRoot, UpdateSourceTrigger=PropertyChanged}"
                                               Height="30" VerticalContentAlignment="Center"
                                               Padding="6,0" FontFamily="Consolas" FontSize="12"
                                               ToolTip="e.g. C:\inetpub\patches"/>
                                </Grid>
                            </Grid>

                            <!-- Row 4: Source folder -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Source Folder"
                                           Style="{StaticResource SectionLabel}"
                                           ToolTip="Patch or publish folder to ZIP and upload. The entire folder is zipped and uploaded as a single file."/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding Transfer.SourceFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                         Height="30" VerticalContentAlignment="Center"
                                         Padding="6,0" FontFamily="Consolas" FontSize="12"
                                         ToolTip="Select the folder to ZIP and send"/>
                                <Button Grid.Column="2"
                                        Content="Browse…"
                                        Command="{Binding Transfer.BrowseSourceCommand}"
                                        Style="{StaticResource SmallBtn}"
                                        Height="30"/>
                                <TextBlock Grid.Column="4"
                                           FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                                           VerticalAlignment="Center"
                                           Text="The full folder is zipped (FolderName_yyyyMMdd_HHmmss.zip) then uploaded to the FTP/SMB target."/>
                            </Grid>

                            <!-- Row 6: Progress + Status + Buttons -->
                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ProgressBar Grid.Row="0" Height="8"
                                                 Value="{Binding Transfer.TransferProgress, Mode=OneWay}"
                                                 Maximum="100"
                                                 Foreground="#0369A1" Background="{DynamicResource SurfaceMutedBrush}"/>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Transfer.CurrentStatus}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </Grid>

                                <Button Grid.Column="2"
                                        Content="Test Connection"
                                        Command="{Binding Transfer.TestConnectionCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#1D4ED8"/>

                                <Button Grid.Column="4"
                                        Content="⬆  Zip &amp; Transfer"
                                        Command="{Binding Transfer.ZipAndTransferCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#059669"/>

                                <Button Grid.Column="6"
                                        Content="■  Cancel"
                                        Command="{Binding Transfer.CancelCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#B91C1C"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── TRANSFER LOG ──────────────────────────────────────────── -->
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Transfer Log"
                                               Style="{StaticResource SectionLabel}" FontSize="13"/>
                                    <Border Background="#E0F2FE" CornerRadius="10" Padding="7,1"
                                            Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="#0369A1">
                                            <Run Text="{Binding Transfer.TransferLog.Count, Mode=OneWay}"/>
                                            <Run Text=" entries"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <Button HorizontalAlignment="Right"
                                        Content="Clear Log"
                                        Command="{Binding Transfer.ClearLogCommand}"
                                        Style="{StaticResource SmallBtn}"/>
                            </Grid>

                            <ListBox Grid.Row="1"
                                     x:Name="TransferLogList"
                                     ItemsSource="{Binding Transfer.TransferLog}"
                                     Background="Transparent"
                                     BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="11"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"          Value="0"/>
                                        <Setter Property="Margin"           Value="0"/>
                                        <Setter Property="Background"       Value="Transparent"/>
                                        <Setter Property="BorderThickness"  Value="0"/>
                                        <Setter Property="Focusable"        Value="False"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   Foreground="{Binding Foreground}"
                                                   TextWrapping="NoWrap"
                                                   Padding="6,1"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════════ -->
            <!-- DEPLOY TAB (IIS configuration only — files are moved via Transfer) -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <TabItem Header="  Deploy  " FontSize="13">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- top: connection + IIS fields -->
                        <RowDefinition Height="Auto"/>  <!-- middle: per-project pool grid (hidden in single-pool mode) -->
                        <RowDefinition Height="*"/>     <!-- main: options + log -->
                    </Grid.RowDefinitions>

                    <!-- ── TOP SECTION: Connection + IIS config ─────────────────────── -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- 0: Server + Credentials -->
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>  <!-- 2: Deploy Root + IIS + Pool + Alias -->
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>  <!-- 4: Progress + Status + Buttons -->
                            </Grid.RowDefinitions>

                            <!-- Row 0: Server + Credentials -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Server / Host" Style="{StaticResource SectionLabel}"/>
                                <TextBox   Grid.Column="1"
                                           Text="{Binding Deploy.ServerHostname, UpdateSourceTrigger=PropertyChanged}"
                                           Height="30" VerticalContentAlignment="Center"
                                           Padding="6,0" FontFamily="Consolas" FontSize="12"
                                           ToolTip="IP address or hostname of the target server"/>

                                <TextBlock Grid.Column="3" Text="Username" Style="{StaticResource SectionLabel}"/>
                                <TextBox   Grid.Column="4"
                                           Text="{Binding Deploy.Username, UpdateSourceTrigger=PropertyChanged}"
                                           Height="30" VerticalContentAlignment="Center"
                                           Padding="6,0" FontFamily="Consolas" FontSize="12"/>

                                <TextBlock Grid.Column="6" Text="Password" Style="{StaticResource SectionLabel}"/>
                                <PasswordBox Grid.Column="7"
                                             x:Name="DeployPasswordBox"
                                             PasswordChanged="DeployPasswordBox_PasswordChanged"
                                             Height="30"
                                             Padding="6,4"
                                             FontFamily="Consolas" FontSize="12"
                                             Background="{DynamicResource InputBackgroundBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"/>
                            </Grid>

                            <!-- Row 2: Deploy Root + IIS Site + App Pool + Alias -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"  Text="Deploy Root" Style="{StaticResource SectionLabel}"
                                           ToolTip="Physical path on the server used as the IIS application root. e.g. C:\inetpub\wwwroot"/>
                                <TextBox   Grid.Column="1"
                                           Text="{Binding Deploy.DeploymentRoot, UpdateSourceTrigger=PropertyChanged}"
                                           Height="30" VerticalContentAlignment="Center"
                                           Padding="6,0" FontFamily="Consolas" FontSize="12"
                                           ToolTip="e.g. C:\inetpub\wwwroot"/>

                                <TextBlock Grid.Column="3"  Text="IIS Site" Style="{StaticResource SectionLabel}"/>
                                <TextBox   Grid.Column="4"
                                           Text="{Binding Deploy.IisSiteName, UpdateSourceTrigger=PropertyChanged}"
                                           Height="30" VerticalContentAlignment="Center"
                                           Padding="6,0" FontFamily="Consolas" FontSize="12"
                                           ToolTip="Existing IIS site name e.g. Default Web Site"/>

                                <TextBlock Grid.Column="6"  Text="App Pool" Style="{StaticResource SectionLabel}"/>
                                <TextBox   Grid.Column="7"
                                           Text="{Binding Deploy.AppPoolName, UpdateSourceTrigger=PropertyChanged}"
                                           Height="30" VerticalContentAlignment="Center"
                                           Padding="6,0" FontFamily="Consolas" FontSize="12"/>

                                <TextBlock Grid.Column="9"  Text="Alias" Style="{StaticResource SectionLabel}"
                                           ToolTip="IIS application alias (optional — defaults to project name)"/>
                                <TextBox   Grid.Column="10"
                                           Text="{Binding Deploy.ApplicationAlias, UpdateSourceTrigger=PropertyChanged}"
                                           Height="30" VerticalContentAlignment="Center"
                                           Padding="6,0" FontFamily="Consolas" FontSize="12"
                                           ToolTip="Optional — leave blank to use the project name"/>
                            </Grid>

                            <!-- Row 4: Progress + Status + Buttons -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ProgressBar Grid.Row="0" Height="8"
                                                 Value="{Binding Deploy.DeployProgress, Mode=OneWay}"
                                                 Maximum="100"
                                                 Foreground="#059669" Background="{DynamicResource SurfaceMutedBrush}"/>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Deploy.CurrentStatus}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </Grid>

                                <Button Grid.Column="2"
                                        Content="Test Connection"
                                        Command="{Binding Deploy.TestConnectionCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#1D4ED8"/>

                                <Button Grid.Column="4"
                                        Content="▶  Deploy IIS"
                                        Command="{Binding Deploy.DeployCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#059669"/>

                                <Button Grid.Column="6"
                                        Content="■  Cancel"
                                        Command="{Binding Deploy.CancelDeployCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#B91C1C"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── PER-PROJECT POOL CONFIGURATION (hidden in single-pool mode) ── -->
                    <Border Grid.Row="1" Margin="0,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Deploy.UsePerProjectPools}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Grid Grid.Row="0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Per-Project Pool Configuration"
                                               Style="{StaticResource SectionLabel}" FontSize="13"/>
                                    <Border Background="#E0F2FE" CornerRadius="10" Padding="7,1"
                                            Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="#0369A1">
                                            <Run Text="{Binding Deploy.ProjectDeployConfigs.Count, Mode=OneWay}"/>
                                            <Run Text=" projects"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="All"  Command="{Binding Deploy.SelectAllConfigsCommand}"
                                            Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                    <Button Content="None" Command="{Binding Deploy.ClearAllConfigsCommand}"
                                            Style="{StaticResource SmallBtn}" Margin="0,0,8,0"/>
                                    <Button Content="↻  Refresh from Projects"
                                            Command="{Binding Deploy.RefreshProjectConfigsCommand}"
                                            Style="{StaticResource PrimaryBtn}"
                                            Background="#1D4ED8" Height="26" FontSize="11" Padding="10,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Pool naming prefix -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pool Name Prefix"
                                           Style="{StaticResource SectionLabel}" Margin="0,0,8,0"
                                           ToolTip="Auto-prefix added to pool names when refreshing e.g. HRMS_"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding Deploy.PoolNamingPrefix, UpdateSourceTrigger=PropertyChanged}"
                                         Height="26" VerticalContentAlignment="Center"
                                         Padding="6,0" FontFamily="Consolas" FontSize="12"
                                         ToolTip="e.g. HRMS_  →  pools named HRMS_ServiceA, HRMS_ServiceB…"/>
                                <TextBlock Grid.Column="2"
                                           Text="Prefix is applied when you click Refresh. Edit pool names directly in the grid below."
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>

                            <!-- Per-project pool DataGrid -->
                            <DataGrid Grid.Row="4"
                                      ItemsSource="{Binding Deploy.ProjectDeployConfigs}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderBrushTheme}"
                                      BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}"
                                      RowHeight="30" FontSize="11"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      EnableRowVirtualization="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">

                                <DataGrid.Columns>
                                    <!-- Deploy checkbox -->
                                    <DataGridTemplateColumn Header="✓" Width="36" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Project name (read-only) -->
                                    <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" IsReadOnly="True" Width="160">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- App Pool Name (editable) -->
                                    <DataGridTextColumn Header="App Pool Name"
                                                        Binding="{Binding AppPoolName, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="180">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Application Alias (editable) -->
                                    <DataGridTextColumn Header="IIS Alias"
                                                        Binding="{Binding ApplicationAlias, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- CLR Version (ComboBox) -->
                                    <DataGridComboBoxColumn Header=".NET CLR" Width="115"
                                                            SelectedItemBinding="{Binding DotNetClrVersion, UpdateSourceTrigger=PropertyChanged}">
                                        <DataGridComboBoxColumn.ElementStyle>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="ItemsSource"
                                                        Value="{Binding DataContext.Deploy.ClrVersionOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                <Setter Property="IsEditable" Value="False"/>
                                            </Style>
                                        </DataGridComboBoxColumn.ElementStyle>
                                        <DataGridComboBoxColumn.EditingElementStyle>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="ItemsSource"
                                                        Value="{Binding DataContext.Deploy.ClrVersionOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </Style>
                                        </DataGridComboBoxColumn.EditingElementStyle>
                                    </DataGridComboBoxColumn>

                                    <!-- Pipeline Mode (ComboBox) -->
                                    <DataGridComboBoxColumn Header="Pipeline" Width="105"
                                                            SelectedItemBinding="{Binding PipelineMode, UpdateSourceTrigger=PropertyChanged}">
                                        <DataGridComboBoxColumn.ElementStyle>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="ItemsSource"
                                                        Value="{Binding DataContext.Deploy.PipelineModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                <Setter Property="IsEditable" Value="False"/>
                                            </Style>
                                        </DataGridComboBoxColumn.ElementStyle>
                                        <DataGridComboBoxColumn.EditingElementStyle>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="ItemsSource"
                                                        Value="{Binding DataContext.Deploy.PipelineModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </Style>
                                        </DataGridComboBoxColumn.EditingElementStyle>
                                    </DataGridComboBoxColumn>

                                    <!-- 32-bit checkbox -->
                                    <DataGridTemplateColumn Header="32-bit" Width="58" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding Enable32Bit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- ── MAIN SECTION: Options (left) + Log viewer (right) ──────────── -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Deployment options + pool settings ─────────────────── -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <!-- Deployment options header -->
                                <TextBlock Text="Deployment Options"
                                           Style="{StaticResource SectionLabel}" FontSize="13"
                                           Margin="0,0,0,10"/>

                                <CheckBox Content="Create App Pool"
                                          IsChecked="{Binding Deploy.CreateAppPool}"
                                          Margin="0,0,0,6"/>
                                <CheckBox Content="Create IIS Application"
                                          IsChecked="{Binding Deploy.CreateIisApplication}"
                                          Margin="0,0,0,6"/>
                                <CheckBox Content="Start App Pool After Deploy"
                                          IsChecked="{Binding Deploy.StartAppPoolAfterDeploy}"
                                          Margin="0,0,0,14"/>

                                <!-- Separator -->
                                <Border Height="1" Background="{DynamicResource BorderBrushTheme}" Margin="0,0,0,12"/>

                                <!-- Pool settings header -->
                                <TextBlock Text="App Pool Settings"
                                           Style="{StaticResource SectionLabel}" FontSize="13"
                                           Margin="0,0,0,10"/>

                                <!-- .NET CLR Version -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text=".NET CLR Version"
                                               Style="{StaticResource SectionLabel}" FontSize="11"/>
                                    <ComboBox  Grid.Column="1"
                                               ItemsSource="{Binding Deploy.ClrVersionOptions}"
                                               SelectedItem="{Binding Deploy.DotNetClrVersion}"
                                               Height="28" VerticalContentAlignment="Center" FontSize="11"/>
                                </Grid>

                                <!-- Pipeline Mode -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pipeline Mode"
                                               Style="{StaticResource SectionLabel}" FontSize="11"/>
                                    <ComboBox  Grid.Column="1"
                                               ItemsSource="{Binding Deploy.PipelineModeOptions}"
                                               SelectedItem="{Binding Deploy.PipelineMode}"
                                               Height="28" VerticalContentAlignment="Center" FontSize="11"/>
                                </Grid>

                                <!-- Enable 32-bit -->
                                <CheckBox Content="Enable 32-bit App On Win64"
                                          IsChecked="{Binding Deploy.Enable32Bit}"
                                          Margin="0,4,0,14"/>

                                <!-- Separator -->
                                <Border Height="1" Background="{DynamicResource BorderBrushTheme}" Margin="0,0,0,12"/>

                                <!-- Pool Mode -->
                                <TextBlock Text="Pool Mode"
                                           Style="{StaticResource SectionLabel}" FontSize="13"
                                           Margin="0,0,0,8"/>

                                <RadioButton Content="Single Pool  (all projects share one pool)"
                                             IsChecked="{Binding Deploy.UseSinglePool}"
                                             GroupName="DeployPoolMode"
                                             Margin="0,0,0,6"
                                             FontSize="11"
                                             ToolTip="One App Pool assigned to all deployed applications"/>

                                <RadioButton Content="Per-Project Pools  (each project gets its own pool)"
                                             IsChecked="{Binding Deploy.UsePerProjectPools}"
                                             GroupName="DeployPoolMode"
                                             Margin="0,0,0,4"
                                             FontSize="11"
                                             ToolTip="Each microservice/application gets a dedicated App Pool"/>

                                <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Per-project mode: use the grid above the log to configure each pool.  Pool Name field becomes the default template.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Deploy.UsePerProjectPools}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- RIGHT: Deploy log viewer ──────────────────────────────────── -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Deployment Log"
                                                   Style="{StaticResource SectionLabel}" FontSize="13"/>
                                        <Border Background="#E0F2FE" CornerRadius="10" Padding="7,1"
                                                Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" Foreground="#0369A1">
                                                <Run Text="{Binding Deploy.DeployLog.Count, Mode=OneWay}"/>
                                                <Run Text=" entries"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right"
                                            Content="Clear Log"
                                            Command="{Binding Deploy.ClearDeployLogCommand}"
                                            Style="{StaticResource SmallBtn}"/>
                                </Grid>

                                <ListBox Grid.Row="1"
                                         x:Name="DeployLogList"
                                         ItemsSource="{Binding Deploy.DeployLog}"
                                         Background="Transparent"
                                         BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="11"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding"         Value="0"/>
                                            <Setter Property="Margin"          Value="0"/>
                                            <Setter Property="Background"      Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Focusable"       Value="False"/>
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayText}"
                                                       Foreground="{Binding Foreground}"
                                                       TextWrapping="NoWrap"
                                                       Padding="6,1"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════════ -->
            <!-- VB PUBLISHER TAB                                                  -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <!-- VB PUBLISHER  (advanced 4-tab workflow)                        -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <TabItem Header="  VB Publisher  " FontSize="13">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- workflow header strip -->
                        <RowDefinition Height="*"/>      <!-- sub-tab content -->
                    </Grid.RowDefinitions>

                    <!-- ── Workflow header strip ─────────────────────────────────── -->
                    <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="6" Margin="0,0,0,6" Padding="12,6">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="VB Publisher Workflow" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#93C5FD" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <!-- Workflow step indicators -->
                                <Border Background="#1D4ED8" CornerRadius="12" Padding="8,2" Margin="0,0,4,0">
                                    <TextBlock Text="1  Repos" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Text="→" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Border Background="#7C3AED" CornerRadius="12" Padding="8,2" Margin="0,0,4,0">
                                    <TextBlock Text="2  Sync" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Text="→" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Border Background="#059669" CornerRadius="12" Padding="8,2" Margin="0,0,4,0">
                                    <TextBlock Text="3  Build" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Text="→" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Border Background="#B45309" CornerRadius="12" Padding="8,2">
                                    <TextBlock Text="4  Patch" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <!-- Cross-tab actions -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Push Mini → Build"
                                        Command="{Binding VbPublisher.PushMiniToBuildCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#059669" Margin="0,0,6,0"
                                        ToolTip="Copy Mini Code path from Code Sync into Build Pipeline and switch to Build tab"/>
                                <Button Content="Build → Patch"
                                        Command="{Binding VbPublisher.PushBuildToPatchCommand}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="#B45309"
                                        ToolTip="Send publish output path to Patch tab (Single Folder mode)"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Sub-tab control ───────────────────────────────────────── -->
                    <TabControl Grid.Row="1"
                                SelectedIndex="{Binding VbPublisher.SelectedTabIndex}"
                                Background="Transparent" BorderThickness="0" Padding="0">

                        <!-- ─── TAB 1: REPOSITORIES ──────────────────────────────── -->
                        <TabItem FontSize="12">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#1D4ED8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Repositories"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: repo list + branch list -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>   <!-- 0: Repos header + toggle -->
                                        <RowDefinition Height="Auto"/>   <!-- 1: Repos collapsible section -->
                                        <RowDefinition Height="6"/>      <!-- 2: spacer -->
                                        <RowDefinition Height="Auto"/>   <!-- 3: Branches label -->
                                        <RowDefinition Height="*"/>      <!-- 4: Branches ListBox -->
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Repos header with toggle + CRUD buttons -->
                                    <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                                            BorderBrush="{DynamicResource BorderBrushTheme}" BorderThickness="1"
                                            CornerRadius="4" Padding="4,3" Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Command="{Binding VbPublisher.Repositories.ToggleRepoListCommand}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="2,0,4,0">
                                                <TextBlock FontSize="9" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="▼"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding VbPublisher.Repositories.IsRepoListExpanded}" Value="False">
                                                                    <Setter Property="Text" Value="▶"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                            <TextBlock Grid.Column="1" Text="REPOSITORIES"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="+" Command="{Binding VbPublisher.Repositories.AddRepoCommand}"
                                                        Style="{StaticResource SmallBtn}" Padding="5,1" Margin="0,0,2,0"
                                                        ToolTip="Add repository"/>
                                                <Button Content="−" Command="{Binding VbPublisher.Repositories.RemoveRepoCommand}"
                                                        Style="{StaticResource SmallBtn}" Padding="5,1" Margin="0,0,2,0"
                                                        ToolTip="Remove selected repository"/>
                                                <Button Content="📁" Command="{Binding VbPublisher.Repositories.BrowseRepoPathCommand}"
                                                        Style="{StaticResource SmallBtn}" Padding="5,1" Margin="0,0,2,0"
                                                        ToolTip="Browse local path for selected repository"/>
                                                <Button Content="💾" Command="{Binding VbPublisher.Repositories.SaveReposCommand}"
                                                        Style="{StaticResource SmallBtn}" Padding="5,1"
                                                        ToolTip="Save repositories to appsettings.json"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Row 1: Collapsible DataGrid of repositories -->
                                    <Border Grid.Row="1"
                                            Visibility="{Binding VbPublisher.Repositories.IsRepoListExpanded, Converter={StaticResource BoolToVis}}"
                                            BorderBrush="{DynamicResource BorderBrushTheme}" BorderThickness="1"
                                            Margin="0,0,0,0">
                                        <DataGrid ItemsSource="{Binding VbPublisher.Repositories.Repositories}"
                                                  SelectedItem="{Binding VbPublisher.Repositories.SelectedRepository}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserReorderColumns="False"
                                                  GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="{DynamicResource BorderBrushTheme}"
                                                  BorderThickness="0"
                                                  RowHeight="30" FontSize="11" Height="160"
                                                  Background="{DynamicResource SurfaceBrush}"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Name"
                                                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="*"/>
                                                <DataGridTextColumn Header="Branch"
                                                                    Binding="{Binding DefaultBranch, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="55"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>

                                    <TextBlock Grid.Row="3" Text="BRANCHES" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,4"/>
                                    <ListBox Grid.Row="4"
                                             ItemsSource="{Binding VbPublisher.Repositories.Branches}"
                                             SelectedItem="{Binding VbPublisher.Repositories.SelectedBranch}"
                                             DisplayMemberPath="DisplayName"
                                             BorderBrush="{DynamicResource BorderBrushTheme}"
                                             BorderThickness="1"
                                             Background="{DynamicResource SurfaceBrush}"
                                             FontSize="11" FontFamily="Consolas">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrentBranch}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground" Value="#059669"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                                        <Setter Property="Foreground" Value="#6B7280"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Grid>

                                <!-- Right: status + git output + commit log -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>  <!-- status card -->
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>  <!-- action buttons -->
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="*"/>     <!-- git output / commit log -->
                                    </Grid.RowDefinitions>

                                    <!-- Status card -->
                                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Clean/Dirty chip -->
                                            <Border Grid.Column="0" CornerRadius="4" Padding="8,3" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding VbPublisher.Repositories.IsClean}" Value="False">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="CLEAN"/>
                                                            <Setter Property="Foreground" Value="#065F46"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding VbPublisher.Repositories.IsClean}" Value="False">
                                                                    <Setter Property="Text" Value="DIRTY"/>
                                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding VbPublisher.Repositories.StatusSummary}"
                                                       FontSize="11" FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding VbPublisher.Repositories.StatusText}"
                                                       FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- Action buttons -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Button Content="↻ Refresh"
                                                Command="{Binding VbPublisher.Repositories.RefreshCommand}"
                                                Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                        <Button Content="⬇ Pull"
                                                Command="{Binding VbPublisher.Repositories.PullCommand}"
                                                Style="{StaticResource PrimaryBtn}"
                                                Background="#1D4ED8" Margin="0,0,4,0"/>
                                        <Button Content="⟳ Fetch"
                                                Command="{Binding VbPublisher.Repositories.FetchCommand}"
                                                Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                        <Button Content="⎇ Checkout"
                                                Command="{Binding VbPublisher.Repositories.CheckoutCommand}"
                                                Style="{StaticResource PrimaryBtn}"
                                                Background="#059669" Margin="0,0,8,0"/>
                                        <!-- Custom git command -->
                                        <TextBox Text="{Binding VbPublisher.Repositories.CustomCommand, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="150" Height="26"
                                                 VerticalContentAlignment="Center" Padding="4,0"
                                                 FontFamily="Consolas" FontSize="11"
                                                 ToolTip="git &lt;your arguments here&gt;" Margin="0,0,4,0"/>
                                        <Button Content="Run"
                                                Command="{Binding VbPublisher.Repositories.RunCustomCommand}"
                                                Style="{StaticResource SmallBtn}" Margin="0,0,8,0"/>
                                        <Button Content="■ Cancel"
                                                Command="{Binding VbPublisher.Repositories.CancelCommand}"
                                                Style="{StaticResource PrimaryBtn}" Background="#B91C1C"/>
                                    </StackPanel>

                                    <!-- Output + commit log (split) -->
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Git output -->
                                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="GIT OUTPUT" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                                    <TextBlock Text="{Binding VbPublisher.Repositories.GitOutput}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>

                                        <!-- Commit log -->
                                        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="RECENT COMMITS" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                                                <ListBox Grid.Row="1"
                                                         ItemsSource="{Binding VbPublisher.Repositories.CommitLog}"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         FontFamily="Consolas" FontSize="10"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="2,1"/>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- ─── TAB 2: CODE SYNC ──────────────────────────────────── -->
                        <TabItem FontSize="12">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#7C3AED" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Code Sync"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- path config -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>  <!-- action + filters -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="*"/>     <!-- file list -->
                                    <RowDefinition Height="Auto"/>  <!-- progress + copy button -->
                                </Grid.RowDefinitions>

                                <!-- Path config card -->
                                <Border Grid.Row="0" Style="{StaticResource Card}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="6"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Main Code"
                                                   Style="{StaticResource SectionLabel}"
                                                   ToolTip="Full source codebase — files are scanned here"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding VbPublisher.CodeSync.MainCodePath, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" VerticalContentAlignment="Center"
                                                 Padding="6,0" FontFamily="Consolas" FontSize="11"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Browse…"
                                                Command="{Binding VbPublisher.CodeSync.BrowseMainCodeCommand}"
                                                Style="{StaticResource SmallBtn}" Height="30" Margin="6,0,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Mini Code"
                                                   Style="{StaticResource SectionLabel}"
                                                   ToolTip="Subset project — changed files are copied here"/>
                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                 Text="{Binding VbPublisher.CodeSync.MiniCodePath, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" VerticalContentAlignment="Center"
                                                 Padding="6,0" FontFamily="Consolas" FontSize="11"/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="Browse…"
                                                Command="{Binding VbPublisher.CodeSync.BrowseMiniCodeCommand}"
                                                Style="{StaticResource SmallBtn}" Height="30" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- Action bar: date filter + scan + select -->
                                <Border Grid.Row="2" Style="{StaticResource Card}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox Content="Date range:"
                                                      IsChecked="{Binding VbPublisher.CodeSync.UseDateRange}"
                                                      VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="From" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <DatePicker SelectedDate="{Binding VbPublisher.CodeSync.FromDate}"
                                                        Height="28" Width="120" FontSize="11"
                                                        IsEnabled="{Binding VbPublisher.CodeSync.DatePickersEnabled}"
                                                        Margin="0,0,8,0"
                                                        ToolTip="Include files modified on or after this date"/>
                                            <TextBlock Text="To" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <DatePicker SelectedDate="{Binding VbPublisher.CodeSync.ToDate}"
                                                        Height="28" Width="120" FontSize="11"
                                                        IsEnabled="{Binding VbPublisher.CodeSync.DatePickersEnabled}"
                                                        Margin="0,0,12,0"
                                                        ToolTip="Include files modified on or before this date"/>
                                            <Button Content="🔍 Scan Changes"
                                                    Command="{Binding VbPublisher.CodeSync.ScanCommand}"
                                                    Style="{StaticResource PrimaryBtn}"
                                                    Background="#7C3AED" Margin="0,0,6,0"/>
                                            <Button Content="■ Cancel"
                                                    Command="{Binding VbPublisher.CodeSync.CancelCommand}"
                                                    Style="{StaticResource PrimaryBtn}" Background="#B91C1C"/>
                                        </StackPanel>

                                        <!-- Counts + select all/none -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border Background="#D1FAE5" CornerRadius="10" Padding="7,1" Margin="0,0,4,0" VerticalAlignment="Center">
                                                <TextBlock FontSize="11" Foreground="#065F46">
                                                    <Run Text="{Binding VbPublisher.CodeSync.NewCount, Mode=OneWay}"/>
                                                    <Run Text=" new"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Background="#FEF9C3" CornerRadius="10" Padding="7,1" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <TextBlock FontSize="11" Foreground="#78350F">
                                                    <Run Text="{Binding VbPublisher.CodeSync.ModifiedCount, Mode=OneWay}"/>
                                                    <Run Text=" modified"/>
                                                </TextBlock>
                                            </Border>
                                            <Button Content="All"
                                                    Command="{Binding VbPublisher.CodeSync.SelectAllCommand}"
                                                    Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                            <Button Content="None"
                                                    Command="{Binding VbPublisher.CodeSync.SelectNoneCommand}"
                                                    Style="{StaticResource SmallBtn}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- File list — same tree view as Patch tab -->
                                <Border Grid.Row="4" Style="{StaticResource Card}" Padding="0">
                                    <TreeView ItemsSource="{Binding VbPublisher.CodeSync.SyncFileTree}"
                                              BorderThickness="0"
                                              Background="{DynamicResource SurfaceBrush}"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="True"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="1,1"/>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                <Border Padding="2,1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FileChange.Status}" Value="New">
                                                                    <Setter Property="Background" Value="{DynamicResource TreeNewBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                                    <Setter Property="Background" Value="{DynamicResource TreeModifiedBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                  VerticalAlignment="Center" Margin="0,0,4,0"/>

                                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                                   Margin="0,0,3,0" FontSize="13">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="📄"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                            <Setter Property="Text" Value="📁"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <TextBlock Grid.Column="2" Text="{Binding Name}"
                                                                   VerticalAlignment="Center"
                                                                   FontFamily="Consolas" FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                                                            <Setter Property="FontSize" Value="12"/>
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <!-- status badge — files only -->
                                                        <Border Grid.Column="3" Margin="6,2,0,2"
                                                                CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                                            <Setter Property="Background" Value="#FEF9C3"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding FileChange.StatusLabel}"
                                                                       FontSize="10" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#065F46"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                                                <Setter Property="Foreground" Value="#78350F"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- timestamp — files only -->
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding FileChange.LastWriteTimeLabel}"
                                                                   FontFamily="Consolas" FontSize="10"
                                                                   Foreground="{DynamicResource TextFaintBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,2,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </Border>

                                <!-- Progress + copy button -->
                                <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,6,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="3"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <ProgressBar Grid.Row="0" Height="6"
                                                         Value="{Binding VbPublisher.CodeSync.Progress, Mode=OneWay}"
                                                         Maximum="100"
                                                         Foreground="#7C3AED"
                                                         Background="{DynamicResource SurfaceMutedBrush}"/>
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding VbPublisher.CodeSync.StatusText}"
                                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </Grid>
                                        <Button Grid.Column="1"
                                                Content="▷  Copy to Mini"
                                                Command="{Binding VbPublisher.CodeSync.CopyToMiniCommand}"
                                                Style="{StaticResource PrimaryBtn}"
                                                Background="#059669" Margin="10,0,0,0"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- ─── TAB 3: BUILD PIPELINE ─────────────────────────────── -->
                        <TabItem FontSize="12">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#059669" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Build Pipeline"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- path config card -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>  <!-- action bar -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="*"/>     <!-- build log -->
                                </Grid.RowDefinitions>

                                <!-- Config card -->
                                <Border Grid.Row="0" Style="{StaticResource Card}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="6"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Row 0: source — switches between Solution and Mini Code Path -->
                                        <!-- Standard mode: Solution / Project -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Solution / Project"
                                                   ToolTip="Path to .sln, .csproj, or .vbproj">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionLabel}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VbPublisher.BuildPipeline.IsVbWebForms}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding VbPublisher.BuildPipeline.SolutionPath, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" VerticalContentAlignment="Center"
                                                 Padding="6,0" FontFamily="Consolas" FontSize="11">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VbPublisher.BuildPipeline.IsVbWebForms}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Browse…"
                                                Command="{Binding VbPublisher.BuildPipeline.BrowseSolutionCommand}"
                                                Height="30" Margin="6,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallBtn}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VbPublisher.BuildPipeline.IsVbWebForms}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- VB WebForms mode: Mini Code Path (auto-filled from Code Sync) -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mini Code Path"
                                                   ToolTip="Compiled from the mini (subset) codebase — auto-filled from Code Sync tab">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionLabel}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VbPublisher.BuildPipeline.IsVbWebForms}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding VbPublisher.BuildPipeline.MiniCodePath, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" VerticalContentAlignment="Center"
                                                 Padding="6,0" FontFamily="Consolas" FontSize="11">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VbPublisher.BuildPipeline.IsVbWebForms}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Browse…"
                                                Command="{Binding VbPublisher.BuildPipeline.BrowseMiniCodePathCommand}"
                                                Height="30" Margin="6,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SmallBtn}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VbPublisher.BuildPipeline.IsVbWebForms}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Publish Output"
                                                   Style="{StaticResource SectionLabel}"/>
                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                 Text="{Binding VbPublisher.BuildPipeline.PublishOutputPath, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30" VerticalContentAlignment="Center"
                                                 Padding="6,0" FontFamily="Consolas" FontSize="11"/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="Browse…"
                                                Command="{Binding VbPublisher.BuildPipeline.BrowsePublishOutputCommand}"
                                                Style="{StaticResource SmallBtn}" Height="30" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- Action bar -->
                                <Border Grid.Row="2" Style="{StaticResource Card}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Config:" Style="{StaticResource SectionLabel}" Margin="0,0,6,0"/>
                                            <ComboBox ItemsSource="{Binding VbPublisher.BuildPipeline.Configurations}"
                                                      SelectedItem="{Binding VbPublisher.BuildPipeline.SelectedConfiguration}"
                                                      Width="90" Height="28" Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                                            <CheckBox Content="VB WebForms (aspnet_compiler)"
                                                      IsChecked="{Binding VbPublisher.BuildPipeline.IsVbWebForms}"
                                                      VerticalAlignment="Center" Margin="0,0,16,0"/>
                                            <Button Content="⚙  Build"
                                                    Command="{Binding VbPublisher.BuildPipeline.BuildCommand}"
                                                    Style="{StaticResource PrimaryBtn}"
                                                    Background="#059669" Margin="0,0,6,0"/>
                                            <Button Content="▶  Publish"
                                                    Command="{Binding VbPublisher.BuildPipeline.PublishCommand}"
                                                    Style="{StaticResource PrimaryBtn}"
                                                    Background="#7C3AED" Margin="0,0,6,0"/>
                                            <Button Content="Clear Log"
                                                    Command="{Binding VbPublisher.BuildPipeline.ClearLogCommand}"
                                                    Style="{StaticResource SmallBtn}" Margin="0,0,6,0"/>
                                            <Button Content="■ Cancel"
                                                    Command="{Binding VbPublisher.BuildPipeline.CancelCommand}"
                                                    Style="{StaticResource PrimaryBtn}" Background="#B91C1C"/>
                                        </StackPanel>

                                        <!-- Result chip + progress -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <ProgressBar IsIndeterminate="True" Width="100" Height="6"
                                                         Foreground="#059669" Background="#D1FAE5" Margin="0,0,8,0"
                                                         Visibility="{Binding VbPublisher.BuildPipeline.IsWorking, Converter={StaticResource BoolToVis}}"/>
                                            <Border CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                                                    Visibility="{Binding VbPublisher.BuildPipeline.LastBuildSuccess, Converter={StaticResource BoolToVis}}">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#D1FAE5"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding VbPublisher.BuildPipeline.LastResultSummary}"
                                                           FontSize="11" Foreground="#065F46"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Build log -->
                                <Border Grid.Row="4" Style="{StaticResource Card}" Padding="6">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="BUILD LOG" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding VbPublisher.BuildPipeline.BuildLog}"
                                                 BorderThickness="0"
                                                 Background="{DynamicResource SurfaceBrush}"
                                                 FontFamily="Consolas" FontSize="10"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="2,0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="">
                                                            <Setter Property="Height" Value="4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- ─── TAB 4: PATCH GENERATOR ────────────────────────────── -->
                        <TabItem FontSize="12">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#B45309" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Patch Generator"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="0,8,0,0">
                                <Border Style="{StaticResource Card}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- title bar -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Compare &amp; Patch" Style="{StaticResource SectionLabel}" FontSize="13"/>
                                                <Border Background="#FEF3C7" CornerRadius="10" Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock FontSize="11" Foreground="#92400E">
                                                        <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                                        <Run Text=" total"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#FEF9C3" CornerRadius="10" Padding="7,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock FontSize="11" Foreground="#78350F">
                                                        <Run Text="{Binding ModifiedCount, Mode=OneWay}"/>
                                                        <Run Text=" modified"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#D1FAE5" CornerRadius="10" Padding="7,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock FontSize="11" Foreground="#065F46">
                                                        <Run Text="{Binding NewCount, Mode=OneWay}"/>
                                                        <Run Text=" new"/>
                                                    </TextBlock>
                                                </Border>
                                                <ComboBox ItemsSource="{Binding FilterOptions}"
                                                          SelectedItem="{Binding SelectedFilterOption}"
                                                          DisplayMemberPath="Label"
                                                          Height="26" Width="130"
                                                          Margin="10,0,0,0"
                                                          VerticalContentAlignment="Center"
                                                          FontSize="11"/>
                                                <ComboBox ItemsSource="{Binding CompareModeOptions}"
                                                          SelectedItem="{Binding SelectedCompareModeOption}"
                                                          DisplayMemberPath="Label"
                                                          Height="26" Width="120"
                                                          Margin="6,0,0,0"
                                                          VerticalContentAlignment="Center"
                                                          FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- compare progress bar -->
                                        <Grid Grid.Row="1" Margin="0,0,0,4"
                                              Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Grid.Column="0" IsIndeterminate="True" Height="6"
                                                         Foreground="#1D4ED8" Background="#DBEAFE"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Comparing…" FontSize="10"
                                                       Foreground="#1D4ED8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>

                                        <!-- Two-folder: NEW folder row -->
                                        <Grid Grid.Row="2" Margin="0,0,0,4"
                                              Visibility="{Binding IsTwoFolderMode, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="NEW" FontSize="10" FontWeight="Bold"
                                                       Foreground="#065F46" Background="#D1FAE5"
                                                       Padding="4,2" VerticalAlignment="Center" TextAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding NewCompareFolder, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="26" VerticalContentAlignment="Center"
                                                     Padding="4,0" FontFamily="Consolas" FontSize="11"
                                                     BorderBrush="#D1D5DB" Margin="4,0"/>
                                            <Button Grid.Column="2" Content="Browse"
                                                    Command="{Binding BrowseNewCompareFolderCommand}"
                                                    Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                            <Button Grid.Column="3" Content="&#x21C4; Compare"
                                                    Command="{Binding CompareCommand}"
                                                    Style="{StaticResource SmallBtn}"
                                                    Background="#1D4ED8" Foreground="White" BorderThickness="0"
                                                    FontWeight="SemiBold"/>
                                        </Grid>

                                        <!-- Single-folder: FOLDER input row -->
                                        <Grid Grid.Row="2" Margin="0,0,0,4">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSingleFolderMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="FOLDER" FontSize="9" FontWeight="Bold"
                                                       Foreground="#1D4ED8" Background="#DBEAFE"
                                                       Padding="4,2" VerticalAlignment="Center" TextAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding SingleCompareFolder, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="26" VerticalContentAlignment="Center"
                                                     Padding="4,0" FontFamily="Consolas" FontSize="11"
                                                     BorderBrush="#D1D5DB" Margin="4,0"/>
                                            <Button Grid.Column="2" Content="Browse"
                                                    Command="{Binding BrowseSingleFolderCommand}"
                                                    Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                            <Button Grid.Column="3" Content="&#x1F50D; Scan"
                                                    Command="{Binding CompareCommand}"
                                                    Style="{StaticResource SmallBtn}"
                                                    Background="#1D4ED8" Foreground="White" BorderThickness="0"
                                                    FontWeight="SemiBold"/>
                                        </Grid>

                                        <!-- OLD folder row (two-folder mode only) -->
                                        <Grid Grid.Row="3" Margin="0,0,0,4"
                                              Visibility="{Binding IsTwoFolderMode, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="2" Text="OLD" FontSize="10" FontWeight="Bold"
                                                       Foreground="#92400E" Background="#FEF3C7"
                                                       Padding="4,2" VerticalAlignment="Center" TextAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding OldCompareFolder, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="26" VerticalContentAlignment="Center"
                                                     Padding="4,0" FontFamily="Consolas" FontSize="11"
                                                     BorderBrush="#D1D5DB" Margin="4,0"/>
                                            <Button Grid.Column="2" Content="Browse"
                                                    Command="{Binding BrowseOldCompareFolderCommand}"
                                                    Style="{StaticResource SmallBtn}"/>
                                        </Grid>

                                        <!-- Since Date row (single folder mode only) -->
                                        <Grid Grid.Row="4" Margin="0,0,0,4">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSingleFolderMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Since" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <DatePicker Grid.Column="1"
                                                        SelectedDate="{Binding SinceDate, UpdateSourceTrigger=PropertyChanged}"
                                                        Height="26" FontSize="11" Margin="0,0,8,0"
                                                        ToolTip="Show files modified or created on/after this date"/>
                                            <TextBlock Grid.Column="2" FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                                                       VerticalAlignment="Center"
                                                       Text="Files modified/created on or after this date"/>
                                        </Grid>

                                        <!-- search bar -->
                                        <Grid Grid.Row="5" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="🔍" FontSize="13"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <Grid Grid.Column="1">
                                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="26" VerticalContentAlignment="Center"
                                                         Padding="6,0" FontFamily="Consolas" FontSize="11"
                                                         BorderBrush="#D1D5DB"/>
                                                <TextBlock Text="Search files…" Foreground="{DynamicResource TextFaintBrush}"
                                                           FontStyle="Italic" FontSize="11"
                                                           VerticalAlignment="Center" Margin="8,0"
                                                           IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                                <Button Content="All"  Command="{Binding SelectAllChangesCommand}" Style="{StaticResource SmallBtn}" Margin="0,0,4,0"/>
                                                <Button Content="None" Command="{Binding ClearChangesCommand}"     Style="{StaticResource SmallBtn}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- file tree -->
                                        <TreeView Grid.Row="6"
                                                  ItemsSource="{Binding FileTree}"
                                                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrushTheme}"
                                                  Background="{DynamicResource SurfaceBrush}"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <TreeView.ItemContainerStyle>
                                                <Style TargetType="TreeViewItem">
                                                    <Setter Property="IsExpanded" Value="True"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="1,1"/>
                                                </Style>
                                            </TreeView.ItemContainerStyle>
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <Border Padding="2,1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FileChange.Status}" Value="New">
                                                                        <Setter Property="Background" Value="{DynamicResource TreeNewBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                                        <Setter Property="Background" Value="{DynamicResource TreeModifiedBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                      VerticalAlignment="Center" Margin="0,0,4,0"/>

                                                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                                       Margin="0,0,3,0" FontSize="13">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="📄"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                                <Setter Property="Text" Value="📁"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <TextBlock Grid.Column="2" Text="{Binding Name}"
                                                                       VerticalAlignment="Center"
                                                                       FontFamily="Consolas" FontSize="11">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                                                <Setter Property="FontSize" Value="12"/>
                                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <!-- status badge — files only -->
                                                            <Border Grid.Column="3" Margin="6,2,0,2"
                                                                    CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                                                <Setter Property="Background" Value="#FEF9C3"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding FileChange.Status}" Value="Unchanged">
                                                                                <Setter Property="Background" Value="#F3F4F6"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding FileChange.StatusLabel}"
                                                                           FontSize="10" FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#065F46"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding FileChange.Status}" Value="Modified">
                                                                                    <Setter Property="Foreground" Value="#78350F"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileChange.Status}" Value="Unchanged">
                                                                                    <Setter Property="Foreground" Value="#6B7280"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                                            <!-- timestamp — files only -->
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding FileChange.LastWriteTimeLabel}"
                                                                       FontFamily="Consolas" FontSize="10"
                                                                       Foreground="{DynamicResource TextFaintBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="8,0,2,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>

                                        <!-- patch config -->
                                        <Grid Grid.Row="7" Margin="0,8,0,4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- patch output root (read-only) -->
                                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Output" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding PatchOutputRoot, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         Height="24" VerticalContentAlignment="Center"
                                                         Padding="4,0" FontFamily="Consolas" FontSize="10"
                                                         Background="{DynamicResource SurfaceMutedBrush}"
                                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                                         ToolTip="{Binding PatchOutputRoot}"/>
                                            </Grid>

                                            <!-- patch folder name (editable) -->
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Name" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding PatchName, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="24" VerticalContentAlignment="Center"
                                                         Padding="4,0" FontFamily="Consolas" FontSize="11"
                                                         BorderBrush="#A78BFA"
                                                         ToolTip="Folder name for this patch (inside Output)"/>
                                            </Grid>
                                        </Grid>

                                        <!-- patch button -->
                                        <Button Grid.Row="8"
                                                Content="📦  Create Patch"
                                                Command="{Binding CreatePatchCommand}"
                                                Style="{StaticResource PrimaryBtn}"
                                                Background="#7C3AED"
                                                Margin="0,4,0,0"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ══ LOG PANEL ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource LogPanelBrush}" Margin="10,6,10,8" CornerRadius="6">
            <Grid Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="OUTPUT LOG" Foreground="{DynamicResource TextFaintBrush}" FontSize="10"
                               FontWeight="Bold" VerticalAlignment="Center"/>

                    <!-- log search -->
                    <Grid Grid.Column="1" Margin="10,0">
                        <TextBox Text="{Binding LogSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="22" VerticalContentAlignment="Center"
                                 Padding="6,0" FontFamily="Consolas" FontSize="10"
                                 Background="{DynamicResource LogInputBrush}" Foreground="#D1FAE5"
                                 BorderBrush="{DynamicResource BorderBrushTheme}" BorderThickness="1"
                                 CaretBrush="#34D399"/>
                        <TextBlock Text="🔍  filter log…" Foreground="{DynamicResource TextFaintBrush}"
                                   FontSize="10" FontStyle="Italic"
                                   VerticalAlignment="Center" Margin="7,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LogSearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="2" Content="Clear"
                            FontSize="10" Padding="8,2" Height="22"
                            Background="{DynamicResource LogInputBrush}" Foreground="{DynamicResource TextMutedBrush}"
                            BorderBrush="{DynamicResource BorderBrushTheme}" BorderThickness="1"
                            Cursor="Hand"
                            Click="ClearLog_Click"/>
                </Grid>

                <ListBox Grid.Row="1"
                         x:Name="LogList"
                         ItemsSource="{Binding FilteredLogEntries}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="11">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}"
                                       Foreground="{Binding Foreground}"
                                       TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
